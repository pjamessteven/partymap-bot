# Development Dockerfile for Next.js
FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package*.json ./

# Install dependencies during build
RUN npm install --legacy-peer-deps

# Copy the rest of the app (will be overridden by volume in dev, but ensures node_modules exists)
COPY . .

# Expose the port
EXPOSE 3000

# Default command
CMD ["npm", "run", "dev"]
