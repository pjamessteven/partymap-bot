# PartyMap API
PARTYMAP_API_KEY=your_api_key_here
PARTYMAP_BASE_URL=https://api.partymap.com/api

# Dev Mode (uses local server)
DEV_MODE=false
DEV_PARTYMAP_BASE_URL=http://localhost:5000/api

# Database
DATABASE_URL=postgresql+asyncpg://partymap:partymap@localhost:5432/partymap_bot

# Redis (Celery)
REDIS_URL=redis://localhost:6379/0

# OpenRouter (DeepSeek LLM)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat

# Exa Search API
EXA_API_KEY=your_exa_key_here

# Goabase
GOABASE_ENABLED=true
GOABASE_BASE_URL=https://www.goabase.net/api/party/
GOABASE_SYNC_SCHEDULE=0 2 * * 0

# Browser (Playwright)
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=120000
BROWSER_SLOW_MO=0

# Lineup Extraction
LINEUP_EXTRACTION_ENABLED=true
LINEUP_IMAGE_MAX_SIZE=2097152

# Sync Settings
SYNC_RATE_LIMIT_PER_MINUTE=10
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development
DEBUG=false
