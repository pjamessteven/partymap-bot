{
  "name": "partymap-bot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "docker-compose up -d",
    "dev:logs": "docker-compose up",
    "build": "docker-compose build",
    "stop": "docker-compose down",
    "init": "docker-compose exec api python scripts/init_db.py",
    "api:dev": "cd apps/api && uvicorn src.main:app --reload",
    "web:dev": "cd apps/web && npm run dev",
    "typecheck": "cd apps/web && npm run typecheck"
  },
  "dependencies": {
    "shiki": "^3.23.0"
  }
}
